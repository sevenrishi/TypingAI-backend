# Database
MONGO_URI=mongodb://localhost:27017/typing-ai

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Email Configuration
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=resend
EMAIL_PASSWORD=your_smtp_or_provider_password
EMAIL_FROM=TypingAI <noreply@typingai.live>
SUPPORT_EMAIL=support@typingai.live

# Server
PORT=5000
NODE_ENV=development
